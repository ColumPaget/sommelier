#These are homebrews and demo CDs for the playstation 1. These games are believed legal to download and play
#most of thse links use the archive.org 'compress' system to generate a zip on the fly, and so cannot have sha256 values

# From Archive.org 
* platform=ps1 category=Game;PlayStation1 icon=$(install-dir)/__ia_thumb.jpg

ArmoredCoreDemo url=https://archive.org/compress/slpm-80119
ResidentEvil2Demo url=https://archive.org/compress/resident-evil-2-demo-europe 
PSXMusicDisk url=https://archive.org/download/pmd_source/pmd.zip runwarn="This rom only plays the music in the mednafen emulator"
TombRaider2DemoE3 url=https://archive.org/compress/tr2-e3-psx/formats=ITEM%20TILE,PNG,ARCHIVE%20BITTORRENT,METADATA,UNKNOWN,CUE%20SHEET 
Driver2Demo url=https://archive.org/compress/Driver2DemoEU-PSX/formats=ISO%20IMAGE,CUE%20SHEET,ARCHIVE%20BITTORRENT,METADATA,JPEG,ITEM%20TILE 
MagicCastle url=https://archive.org/download/magic-castle-2021-07-may/Magic_Castle_2021_07_May.zip sha256=a51244c2d8feb193271d0d735b52eeb5d3661b5e7eaf3313793ef0b3e72f7271
Warzone2100Demo url=https://archive.org/compress/warzone2100demo-pal-sled-01787-sonyplaystation1/formats=TEXT,JPEG,UNKNOWN,CUE%20SHEET,ZIP,ITEM%20TILE,ARCHIVE%20BITTORRENT,METADATA extra_category="StrategyGame;Demo"

